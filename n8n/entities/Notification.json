{
  "name": "Notification",
  "type": "object",
  "properties": {
    "booking_id": {
      "type": "string",
      "description": "ID \u0e01\u0e32\u0e23\u0e08\u0e2d\u0e07\u0e17\u0e35\u0e48\u0e40\u0e01\u0e35\u0e48\u0e22\u0e27\u0e02\u0e49\u0e2d\u0e07"
    },
    "recipient_identifier": {
      "type": "string",
      "description": "\u0e23\u0e2b\u0e31\u0e2a\u0e19\u0e34\u0e2a\u0e34\u0e15\u0e2b\u0e23\u0e37\u0e2d email \u0e1c\u0e39\u0e49\u0e23\u0e31\u0e1a\u0e41\u0e08\u0e49\u0e07\u0e40\u0e15\u0e37\u0e2d\u0e19"
    },
    "message": {
      "type": "string",
      "description": "\u0e02\u0e49\u0e2d\u0e04\u0e27\u0e32\u0e21\u0e41\u0e08\u0e49\u0e07\u0e40\u0e15\u0e37\u0e2d\u0e19"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "type": {
      "type": "string",
      "enum": [
        "approved",
        "rejected",
        "cancelled",
        "info"
      ],
      "default": "info"
    }
  },
  "required": [
    "booking_id",
    "recipient_identifier",
    "message"
  ]
}